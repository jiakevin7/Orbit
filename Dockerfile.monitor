FROM python:3.11-slim

WORKDIR /app

COPY requirements/base.txt requirements/base.txt
RUN pip install --no-cache-dir -r requirements/base.txt

COPY orbit/ orbit/
COPY pyproject.toml .

ENV PYTHONPATH=/app

CMD ["uvicorn", "orbit.monitor.app:app", "--host", "0.0.0.0", "--port", "8080", "--log-level", "info"]
