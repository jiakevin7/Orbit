FROM python:3.11-slim

WORKDIR /app

COPY requirements/base.txt requirements/base.txt
COPY requirements/router.txt requirements/router.txt
RUN pip install --no-cache-dir -r requirements/router.txt

COPY orbit/ orbit/
COPY pyproject.toml .

ENV PYTHONPATH=/app

CMD ["uvicorn", "orbit.router.app:app", "--host", "0.0.0.0", "--port", "8000", "--log-level", "info"]
